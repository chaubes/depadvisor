# .env.example — Copy to .env and fill in values

# LLM Configuration (Ollama is default — no key needed)
DEPADVISOR_LLM_PROVIDER=ollama
DEPADVISOR_LLM_MODEL=qwen3:8b

# Ollama base URL (default: http://localhost:11434)
# Change this if Ollama runs on a remote machine on your network
OLLAMA_BASE_URL=http://localhost:11434

# Optional: OpenAI (if you want cloud LLM instead of local)
# OPENAI_API_KEY=sk-...

# Optional: GitHub token for higher API rate limits (60/hr → 5000/hr)
# GITHUB_TOKEN=ghp_...

# Optional: Cache directory
# DEPADVISOR_CACHE_DIR=~/.cache/depadvisor

# LANGSMITH variables (if using LangSmith for tracing)
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_.....
# LANGSMITH_PROJECT="proj_depadvisor"
